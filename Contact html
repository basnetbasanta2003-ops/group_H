  <main id="main-content">

    <section class="page-header">
      <div class="section-inner">
        <p class="hero-tag">Get In Touch</p>
        <h1>Contact Us</h1>
        <p>We would love to hear from you. Fill in the form and we will get back to you within one working day.</p>
      </div>
    </section>

    <section class="contact-section">
      <div class="section-inner contact-grid">

        <div class="contact-form-wrapper">
          <h2>Send a Message</h2>

          <form id="contact-form" novalidate>

            <div class="form-group">
              <label for="name">Full Name <span aria-hidden="true">*</span></label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="e.g. John Smith"
                required
                aria-required="true"
                aria-describedby="name-error"
              >
              <span class="error-msg" id="name-error" role="alert"></span>
            </div>

            <div class="form-group">
              <label for="email">Email Address <span aria-hidden="true">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="e.g. john@example.com"
                required
                aria-required="true"
                aria-describedby="email-error"
              >
              <span class="error-msg" id="email-error" role="alert"></span>
            </div>

            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="e.g. 07700 900000"
                aria-describedby="phone-error"
              >
              <span class="error-msg" id="phone-error" role="alert"></span>
            </div>

            <div class="form-group">
              <label for="subject">Subject <span aria-hidden="true">*</span></label>
              <select
                id="subject"
                name="subject"
                required
                aria-required="true"
                aria-describedby="subject-error"
              >
                <option value="">Please select a subject</option>
                <option value="web-design">Web Design</option>
                <option value="web-development">Web Development</option>
                <option value="consulting">Business Consulting</option>
                <option value="support">IT Support</option>
                <option value="training">Staff Training</option>
                <option value="other">Other</option>
              </select>
              <span class="error-msg" id="subject-error" role="alert"></span>
            </div>

            <div class="form-group">
              <label for="message">Message <span aria-hidden="true">*</span></label>
              <textarea
                id="message"
                name="message"
                placeholder="Write your message here..."
                rows="6"
                required
                aria-required="true"
                aria-describedby="message-error"
                maxlength="500"
              ></textarea>
              <span class="char-count" id="char-count">0 / 500 characters</span>
              <span class="error-msg" id="message-error" role="alert"></span>
            </div>

            <button type="submit" class="btn">Send Message</button>

          </form>

          <div id="form-success" class="success-msg" style="display:none;" role="alert">
            <p>Thank you for your message! We will be in touch within one working day.</p>
          </div>

        </div>

        <div class="contact-info">
          <h2>Our Details</h2>

          <div class="info-block">
            <p class="info-label">&#128205; Address</p>
            <p>123 Business Street<br>London<br>EC1A 1BB</p>
          </div>

          <div class="info-block">
            <p class="info-label">&#128231; Email</p>
            <p>basantabasnetulster@gmail.com</p>
          </div>

          <div class="info-block">
            <p class="info-label">&#128222; Phone</p>
            <p>+44 20 1234 5678</p>
          </div>

          <div class="info-block">
            <p class="info-label">&#128336; Office Hours</p>
            <p>Monday to Friday<br>9:00am to 5:00pm</p>
          </div>
        </div>

      </div>
    </section>

  </main>

